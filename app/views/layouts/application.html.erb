<!DOCTYPE html>
<html lang="vi">
  <head>
    <title><%= content_for(:title) || "RoadMate — Bạn đồng hành trên đường" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="RoadMate">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="Kết nối người có xe với người cần đi — tuyến Hà Nội ↔ Hoà Lạc">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#F8FAFC] text-[#1E293B]" style="font-family: 'Be Vietnam Pro', sans-serif;">
    <%= yield %>
  </body>
</html>

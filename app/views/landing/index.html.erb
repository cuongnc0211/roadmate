<% content_for :title, "RoadMate — Bạn đồng hành trên đường" %>

<%# ===== NAVBAR ===== %>
<nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 cursor-pointer">
      <div class="w-8 h-8 bg-[#059669] rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <span class="text-lg text-[#1E293B]" style="font-weight: 700;">RoadMate</span>
    </a>

    <div class="hidden sm:flex items-center gap-3">
      <a href="/login" class="text-sm text-[#475569] hover:text-[#059669] transition-colors duration-200 cursor-pointer px-3 py-2" style="font-weight: 500;">
        Đăng nhập
      </a>
      <a href="/register" class="text-sm bg-[#059669] hover:bg-emerald-700 text-white px-4 py-2 rounded-lg transition-colors duration-200 cursor-pointer" style="font-weight: 600;">
        Đăng ký miễn phí
      </a>
    </div>

    <button class="sm:hidden p-2 rounded-lg text-[#475569] hover:bg-gray-100 cursor-pointer" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
</nav>

<%# ===== HERO — SEARCH FIRST ===== %>
<section class="relative pt-16 min-h-screen flex flex-col items-center justify-center bg-gradient-to-br from-[#ECFDF5] via-[#F0FDF4] to-[#FFF7ED] px-4 sm:px-6">
  <div class="w-full max-w-2xl mx-auto text-center">

    <%# Eco badge %>
    <div class="mb-3">
      <span class="inline-flex items-center gap-1.5 bg-[#059669]/10 text-[#059669] text-xs px-3 py-1 rounded-full" style="font-weight: 600;">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
        </svg>
        Đi chung xe — vì túi tiền & vì môi trường
      </span>
    </div>

    <h1 class="text-3xl sm:text-4xl md:text-5xl text-[#1E293B] leading-tight mb-3" style="font-weight: 800;">
      Chia sẻ chuyến đi,<br>
      <span class="text-[#059669]">tiết kiệm & xanh hơn</span>
    </h1>
    <p class="text-base sm:text-lg text-[#475569] mb-8 leading-relaxed">
      Kết nối người có xe với người cần đi — trên mọi tuyến đường toàn quốc.<br class="hidden sm:block">
      Ít xe hơn, ít khí thải hơn, ít tắc đường hơn.
    </p>

    <%# ===== SEARCH BOX ===== %>
    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">

      <%# Tab switcher %>
      <div class="flex border-b border-gray-100" role="tablist">
        <button
          id="tab-find-ride"
          onclick="switchTab('find-ride')"
          class="tab-btn flex-1 flex items-center justify-center gap-2 py-3.5 text-sm border-b-2 border-[#059669] bg-[#ECFDF5] text-[#059669] transition-all duration-200 cursor-pointer"
          style="font-weight: 600;"
          aria-selected="true"
          role="tab"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          Tôi cần đi nhờ
        </button>
        <button
          id="tab-find-passenger"
          onclick="switchTab('find-passenger')"
          class="tab-btn flex-1 flex items-center justify-center gap-2 py-3.5 text-sm border-b-2 border-transparent text-[#94A3B8] hover:bg-gray-50 transition-all duration-200 cursor-pointer"
          style="font-weight: 500;"
          aria-selected="false"
          role="tab"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17a2 2 0 100-4 2 2 0 000 4zM16 17a2 2 0 100-4 2 2 0 000 4zM3 11l1.5-5h15L21 11M3 11h18M3 11l-1 3h20l-1-3"/>
          </svg>
          Tôi có xe, tìm khách
        </button>
      </div>

      <%# Search fields %>
      <div class="p-4 sm:p-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">

          <%# Origin input %>
          <div>
            <label for="origin" class="block text-xs text-[#64748B] mb-1.5 text-left" style="font-weight: 600;">Điểm xuất phát</label>
            <div class="relative">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none">
                <svg class="w-4 h-4 text-[#059669]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <input
                type="text"
                id="origin"
                placeholder="VD: Hà Nội, TP.HCM, Đà Nẵng..."
                class="w-full bg-[#F8FAFC] border border-gray-200 rounded-xl pl-9 pr-4 py-3 text-sm text-[#1E293B] focus:outline-none focus:ring-2 focus:ring-[#059669] focus:border-transparent transition-all duration-200"
                style="font-weight: 500;"
              >
            </div>
          </div>

          <%# Destination input %>
          <div>
            <label for="destination" class="block text-xs text-[#64748B] mb-1.5 text-left" style="font-weight: 600;">Điểm đến</label>
            <div class="relative">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none">
                <svg class="w-4 h-4 text-[#F97316]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/>
                </svg>
              </div>
              <input
                type="text"
                id="destination"
                placeholder="VD: Hoà Lạc, Bình Dương, Hải Phòng..."
                class="w-full bg-[#F8FAFC] border border-gray-200 rounded-xl pl-9 pr-4 py-3 text-sm text-[#1E293B] focus:outline-none focus:ring-2 focus:ring-[#059669] focus:border-transparent transition-all duration-200"
                style="font-weight: 500;"
              >
            </div>
          </div>

          <%# Vehicle type %>
          <div id="vehicle-filter">
            <label class="block text-xs text-[#64748B] mb-1.5 text-left" style="font-weight: 600;">Loại xe</label>
            <div class="flex gap-2">
              <button onclick="selectVehicle(this)" class="vehicle-btn flex-1 flex flex-col items-center gap-1 py-2.5 px-2 rounded-xl border-2 border-[#059669] bg-[#ECFDF5] text-[#059669] text-xs cursor-pointer transition-all duration-200" style="font-weight: 600;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Tất cả
              </button>
              <button onclick="selectVehicle(this)" class="vehicle-btn flex-1 flex flex-col items-center gap-1 py-2.5 px-2 rounded-xl border-2 border-gray-200 bg-white text-[#64748B] text-xs hover:border-[#059669] hover:bg-[#ECFDF5] hover:text-[#059669] cursor-pointer transition-all duration-200" style="font-weight: 500;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                </svg>
                Xe máy
              </button>
              <button onclick="selectVehicle(this)" class="vehicle-btn flex-1 flex flex-col items-center gap-1 py-2.5 px-2 rounded-xl border-2 border-gray-200 bg-white text-[#64748B] text-xs hover:border-[#059669] hover:bg-[#ECFDF5] hover:text-[#059669] cursor-pointer transition-all duration-200" style="font-weight: 500;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17a2 2 0 100-4 2 2 0 000 4zM16 17a2 2 0 100-4 2 2 0 000 4zM3 11l1.5-5h15L21 11M3 11h18M3 11l-1 3h20l-1-3"/>
                </svg>
                Ô tô
              </button>
            </div>
          </div>

          <%# Date picker %>
          <div>
            <label for="depart-date" class="block text-xs text-[#64748B] mb-1.5 text-left" style="font-weight: 600;">Ngày đi</label>
            <div class="relative">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none">
                <svg class="w-4 h-4 text-[#94A3B8]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
              <input
                type="date"
                id="depart-date"
                value="<%= Date.today.strftime('%Y-%m-%d') %>"
                min="<%= Date.today.strftime('%Y-%m-%d') %>"
                class="w-full bg-[#F8FAFC] border border-gray-200 rounded-xl pl-9 pr-4 py-3 text-sm text-[#1E293B] focus:outline-none focus:ring-2 focus:ring-[#059669] focus:border-transparent cursor-pointer transition-all duration-200"
                style="font-weight: 500;"
              >
            </div>
          </div>

        </div>

        <%# CTA button %>
        <a
          href="/posts"
          id="search-btn"
          class="block w-full text-center bg-[#F97316] hover:bg-orange-500 active:bg-orange-600 text-white text-base py-3.5 rounded-xl transition-colors duration-200 cursor-pointer"
          style="font-weight: 700;"
        >
          <span id="search-btn-text">Tìm chuyến xe</span>
          <svg class="w-5 h-5 inline ml-1.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </a>

        <p class="mt-3 text-xs text-[#94A3B8] text-center">
          Muốn đăng chuyến của bạn?
          <a href="/posts/new" class="text-[#059669] hover:underline cursor-pointer" style="font-weight: 500;">Đăng ngay miễn phí</a>
        </p>
      </div>
    </div>

    <%# Trust badges %>
    <div class="flex flex-wrap items-center justify-center gap-4 mt-6">
      <% [
        "Miễn phí 100%",
        "Không phí ẩn",
        "Xem SĐT & Zalo ngay"
      ].each do |badge| %>
        <div class="flex items-center gap-1.5 text-sm text-[#475569]">
          <svg class="w-4 h-4 text-[#059669]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <%= badge %>
        </div>
      <% end %>
    </div>

  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden sm:flex flex-col items-center gap-1 text-[#94A3B8] animate-bounce">
    <span class="text-xs">Tìm hiểu thêm</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<%# ===== ECO IMPACT STATS ===== %>
<section class="py-12 sm:py-16 px-4 sm:px-6 bg-[#065F46]">
  <div class="max-w-6xl mx-auto">
    <p class="text-center text-[#6EE7B7] text-sm mb-8" style="font-weight: 500;">Mỗi chuyến đi chung là một hành động nhỏ — tác động lớn</p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
      <% [
        { num: "50–70%", label: "tiết kiệm chi phí\ndi chuyển", icon: "💰" },
        { num: "~2.1kg", label: "CO₂ giảm mỗi\n40km/chuyến", icon: "🌿" },
        { num: "1 xe", label: "thay 2–4 xe\ntrên đường", icon: "🚗" },
        { num: "Toàn quốc", label: "mọi tuyến đường\nViệt Nam", icon: "🗺️" }
      ].each do |stat| %>
        <div>
          <div class="text-2xl sm:text-3xl text-white mb-1" style="font-weight: 800;"><%= stat[:num] %></div>
          <div class="text-xs text-[#A7F3D0] leading-relaxed whitespace-pre-line"><%= stat[:label] %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== HOW IT WORKS ===== %>
<section class="py-16 sm:py-20 px-4 sm:px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl text-[#1E293B] mb-3" style="font-weight: 800;">Cách hoạt động</h2>
      <p class="text-[#475569] text-base max-w-md mx-auto">Chỉ 3 bước đơn giản</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <% [
        { icon: :search, title: "Tìm chuyến", desc: "Nhập điểm đi, điểm đến và ngày khởi hành. Xem danh sách chuyến phù hợp trên mọi tuyến." },
        { icon: :contact, title: "Liên hệ ngay", desc: "Click \"Liên hệ\" để xem SĐT và Zalo của tài xế/khách. Nhắn tin trao đổi trong app." },
        { icon: :go, title: "Lên đường thôi!", desc: "Thoả thuận giá, hẹn giờ và tự thanh toán. Đơn giản, không phí ẩn, không trung gian." }
      ].each_with_index do |item, i| %>
        <div class="flex flex-col items-center text-center">
          <div class="relative mb-4">
            <div class="w-16 h-16 bg-[#ECFDF5] rounded-2xl flex items-center justify-center">
              <% if item[:icon] == :search %>
                <svg class="w-8 h-8 text-[#059669]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              <% elsif item[:icon] == :contact %>
                <svg class="w-8 h-8 text-[#059669]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              <% else %>
                <svg class="w-8 h-8 text-[#059669]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              <% end %>
            </div>
            <span class="absolute -top-2 -right-2 w-6 h-6 bg-[#059669] text-white text-xs rounded-full flex items-center justify-center" style="font-weight: 700;"><%= i + 1 %></span>
          </div>
          <h3 class="text-base text-[#1E293B] mb-2" style="font-weight: 700;"><%= item[:title] %></h3>
          <p class="text-sm text-[#475569] leading-relaxed"><%= item[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== WHO IS IT FOR ===== %>
<section class="py-16 sm:py-20 px-4 sm:px-6 bg-[#F0FDF4]">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl text-[#1E293B] mb-3" style="font-weight: 800;">Dành cho ai?</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div class="bg-white rounded-2xl p-6 sm:p-8 border border-emerald-100 shadow-sm hover:shadow-md transition-shadow duration-200 cursor-default">
        <div class="w-12 h-12 bg-[#ECFDF5] rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-[#059669]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </div>
        <h3 class="text-lg text-[#1E293B] mb-2" style="font-weight: 700;">Bạn cần đi nhờ</h3>
        <p class="text-sm text-[#475569] leading-relaxed mb-4">
          Sinh viên, nhân viên văn phòng, người đi công tác hay du lịch nội địa — ai cũng có thể tìm được chuyến phù hợp.
        </p>
        <ul class="space-y-2">
          <% ["Tiết kiệm 50–70% so với xe ôm công nghệ", "Linh hoạt giờ giấc theo lịch của bạn", "Góp phần giảm xe cá nhân trên đường"].each do |b| %>
            <li class="flex items-center gap-2 text-sm text-[#475569]">
              <svg class="w-4 h-4 text-[#059669] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <%= b %>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="bg-white rounded-2xl p-6 sm:p-8 border border-emerald-100 shadow-sm hover:shadow-md transition-shadow duration-200 cursor-default">
        <div class="w-12 h-12 bg-[#FFF7ED] rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-[#F97316]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17a2 2 0 100-4 2 2 0 000 4zM16 17a2 2 0 100-4 2 2 0 000 4zM3 11l1.5-5h15L21 11M3 11h18M3 11l-1 3h20l-1-3"/>
          </svg>
        </div>
        <h3 class="text-lg text-[#1E293B] mb-2" style="font-weight: 700;">Bạn có xe, có chỗ trống</h3>
        <p class="text-sm text-[#475569] leading-relaxed mb-4">
          Vẫn đi tuyến đó hàng ngày? Chia sẻ chi phí xăng và cầu đường — đi chung vì tiện, không phải chạy Grab.
        </p>
        <ul class="space-y-2">
          <% ["Chia sẻ chi phí xăng và phí cầu đường", "Đăng chuyến hàng ngày chỉ mất 30 giây", "Giảm lượng xe cá nhân — tốt cho môi trường"].each do |b| %>
            <li class="flex items-center gap-2 text-sm text-[#475569]">
              <svg class="w-4 h-4 text-[#059669] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <%= b %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</section>

<%# ===== TRUST / SAFETY ===== %>
<section class="py-16 sm:py-20 px-4 sm:px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl text-[#1E293B] mb-3" style="font-weight: 800;">An toàn & tin cậy</h2>
      <p class="text-[#475569] text-base max-w-md mx-auto">Cộng đồng dựa trên uy tín thực</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <% [

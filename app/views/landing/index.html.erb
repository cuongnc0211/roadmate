        { icon: :phone, color: "#059669", bg: "#ECFDF5", title: "Xác thực SĐT", desc: "Mỗi tài khoản gắn với số điện thoại thực. Không ẩn danh — không lừa đảo." },
        { icon: :map, color: "#059669", bg: "#ECFDF5", title: "Toàn quốc", desc: "Kết nối mọi tuyến đường tại Việt Nam — từ nội thành đến liên tỉnh." }

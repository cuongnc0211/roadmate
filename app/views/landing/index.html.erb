<%# ===== TAB SWITCH SCRIPT ===== %>
<script>
  function switchTab(tab) {
    const findRideTab = document.getElementById('tab-find-ride');
    const findPassengerTab = document.getElementById('tab-find-passenger');
    const vehicleFilter = document.getElementById('vehicle-filter');
    const searchBtnText = document.getElementById('search-btn-text');

    const activeClasses = ['text-[#3B82F6]', 'border-[#3B82F6]', 'bg-[#EFF6FF]', 'font-600'];
    const inactiveClasses = ['text-[#94A3B8]', 'border-transparent', 'font-500'];

    if (tab === 'find-ride') {
      findRideTab.classList.add(...activeClasses);
      findRideTab.classList.remove(...inactiveClasses);
      findPassengerTab.classList.remove(...activeClasses);
      findPassengerTab.classList.add(...inactiveClasses);
      vehicleFilter.style.display = '';
      searchBtnText.textContent = 'Tìm chuyến xe';
    } else {
      findPassengerTab.classList.add(...activeClasses);
      findPassengerTab.classList.remove(...inactiveClasses);
      findRideTab.classList.remove(...activeClasses);
      findRideTab.classList.add(...inactiveClasses);
      vehicleFilter.style.display = 'none';
      searchBtnText.textContent = 'Tìm khách đi cùng';
    }
  }

  function selectVehicle(btn, type) {
    document.querySelectorAll('.vehicle-btn').forEach(function(b) {
      b.classList.remove('border-[#3B82F6]', 'bg-[#EFF6FF]', 'text-[#3B82F6]', 'font-600');
      b.classList.add('border-gray-200', 'bg-white', 'text-[#64748B]', 'font-500');
    });
    btn.classList.remove('border-gray-200', 'bg-white', 'text-[#64748B]', 'font-500');
    btn.classList.add('border-[#3B82F6]', 'bg-[#EFF6FF]', 'text-[#3B82F6]', 'font-600');
  }
</script>

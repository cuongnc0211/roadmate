<% content_for :title, "RoadMate — Bạn đồng hành trên đường" %>

<%# ===== NAVBAR ===== %>
<nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-green-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 cursor-pointer">
      <div class="w-8 h-8 bg-[#16A34A] rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <span class="text-lg text-[#14532D]" style="font-weight: 700;">RoadMate</span>
    </a>

    <div class="hidden sm:flex items-center gap-3">
      <a href="/login" class="text-sm text-[#4B5563] hover:text-[#16A34A] transition-colors duration-200 cursor-pointer px-3 py-2" style="font-weight: 500;">
        Đăng nhập
      </a>
      <a href="/register" class="text-sm bg-[#16A34A] hover:bg-[#15803D] text-white px-4 py-2 rounded-lg transition-colors duration-200 cursor-pointer" style="font-weight: 600;">
        Đăng ký miễn phí
      </a>
    </div>

    <button class="sm:hidden p-2 rounded-lg text-[#4B5563] hover:bg-green-50 cursor-pointer" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
</nav>

<%# ===== HERO ===== %>
<section class="relative pt-16 min-h-screen flex flex-col items-center justify-center bg-gradient-to-br from-[#F0FFF4] via-[#DCFCE7] to-[#F7FEF9] px-4 sm:px-6 overflow-hidden">

  <%# Decorative floating leaves — background layer %>
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">

    <%# Large tree left %>
    <svg class="absolute -left-10 bottom-0 w-48 h-72 text-[#BBF7D0] opacity-70" viewBox="0 0 120 200" fill="currentColor">
      <ellipse cx="45" cy="80" rx="38" ry="50"/>
      <ellipse cx="65" cy="55" rx="32" ry="42"/>
      <ellipse cx="55" cy="95" rx="30" ry="40"/>
      <rect x="50" y="130" width="10" height="60" fill="#86EFAC"/>
    </svg>

    <%# Large tree right %>
    <svg class="absolute -right-8 bottom-0 w-40 h-64 text-[#BBF7D0] opacity-60" viewBox="0 0 120 200" fill="currentColor">
      <ellipse cx="65" cy="75" rx="36" ry="48"/>
      <ellipse cx="45" cy="50" rx="30" ry="40"/>
      <ellipse cx="58" cy="90" rx="28" ry="38"/>
      <rect x="56" y="125" width="10" height="65" fill="#86EFAC"/>
    </svg>

    <%# Small tree mid-left %>
    <svg class="absolute left-[15%] bottom-0 w-24 h-40 text-[#DCFCE7] opacity-80" viewBox="0 0 80 140" fill="currentColor">
      <ellipse cx="40" cy="55" rx="28" ry="38"/>
      <ellipse cx="40" cy="75" rx="25" ry="32"/>
      <rect x="36" y="98" width="8" height="42" fill="#A7F3D0"/>
    </svg>

    <%# Small tree mid-right %>
    <svg class="absolute right-[12%] bottom-0 w-20 h-36 text-[#DCFCE7] opacity-70" viewBox="0 0 80 140" fill="currentColor">
      <ellipse cx="40" cy="52" rx="26" ry="36"/>
      <ellipse cx="40" cy="70" rx="22" ry="30"/>
      <rect x="36" y="92" width="8" height="48" fill="#A7F3D0"/>
    </svg>

    <%# Floating leaf top-left %>
    <svg class="absolute top-28 left-[8%] w-10 h-10 text-[#86EFAC] opacity-50 rotate-45" viewBox="0 0 40 40" fill="currentColor">
      <path d="M20 2 C20 2 38 10 38 28 C28 38 10 38 2 20 C10 10 20 2 20 2Z"/>
    </svg>

    <%# Floating leaf top-right %>
    <svg class="absolute top-24 right-[10%] w-8 h-8 text-[#4ADE80] opacity-40 -rotate-30" viewBox="0 0 40 40" fill="currentColor">
      <path d="M20 2 C20 2 38 10 38 28 C28 38 10 38 2 20 C10 10 20 2 20 2Z"/>
    </svg>

    <%# Floating leaf mid %>
    <svg class="absolute top-1/3 left-[4%] w-6 h-6 text-[#22C55E] opacity-30 rotate-12" viewBox="0 0 40 40" fill="currentColor">
      <path d="M20 2 C20 2 38 10 38 28 C28 38 10 38 2 20 C10 10 20 2 20 2Z"/>
    </svg>

    <%# Branch top-right area %>
    <svg class="absolute top-20 right-[20%] w-14 h-14 text-[#A7F3D0] opacity-40" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <path d="M10 50 Q20 30 35 20"/>
      <path d="M35 20 Q45 10 50 8"/>
      <path d="M35 20 Q25 12 28 5"/>
      <path d="M22 33 Q15 25 18 18"/>
    </svg>

  </div>

  <div class="w-full max-w-2xl mx-auto text-center relative z-10">

    <%# Eco badge %>
    <div class="mb-4">
      <span class="inline-flex items-center gap-1.5 bg-[#16A34A]/10 text-[#16A34A] text-xs px-3 py-1.5 rounded-full border border-[#16A34A]/20" style="font-weight: 600;">
        <%# Leaf icon %>
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17 8C8 10 5.9 16.17 3.82 19.49c.33.08.69.12 1.07.12 2.76 0 6.89-1.73 9.36-6.74.61-1.23 1.64-2.96 2.75-3.87zM22 2S14 2 9 7c-2.65 2.65-3 7.87-3 7.87S9 13 11.87 9.13C13.64 7.36 22 2 22 2z"/>
        </svg>
        Đi chung xe — vì túi tiền & vì môi trường
      </span>
    </div>

    <h1 class="text-3xl sm:text-4xl md:text-5xl text-[#14532D] leading-tight mb-4" style="font-weight: 800;">
      Chia sẻ chuyến đi,<br>
      <span class="text-[#16A34A]">tiết kiệm & xanh hơn</span>
    </h1>
    <p class="text-base sm:text-lg text-[#374151] mb-8 leading-relaxed">
      Kết nối người có xe với người cần đi — trên mọi tuyến đường toàn quốc.<br class="hidden sm:block">
      Ít xe hơn, ít khí thải hơn, ít tắc đường hơn.
    </p>

    <%# ===== SEARCH BOX ===== %>
    <div class="bg-white rounded-2xl shadow-lg border border-green-100 overflow-hidden">

      <%# Tab switcher %>
      <div class="flex border-b border-green-100" role="tablist">
        <button
          id="tab-find-ride"
          onclick="switchTab('find-ride')"
          class="tab-btn flex-1 flex items-center justify-center gap-2 py-3.5 text-sm border-b-2 border-[#16A34A] bg-[#F0FFF4] text-[#16A34A] transition-all duration-200 cursor-pointer"
          style="font-weight: 600;"
          aria-selected="true"
          role="tab"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          Tôi cần đi nhờ
        </button>
        <button
          id="tab-find-passenger"
          onclick="switchTab('find-passenger')"
          class="tab-btn flex-1 flex items-center justify-center gap-2 py-3.5 text-sm border-b-2 border-transparent text-[#6B7280] hover:bg-green-50 transition-all duration-200 cursor-pointer"
          style="font-weight: 500;"
          aria-selected="false"
          role="tab"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17a2 2 0 100-4 2 2 0 000 4zM16 17a2 2 0 100-4 2 2 0 000 4zM3 11l1.5-5h15L21 11M3 11h18M3 11l-1 3h20l-1-3"/>
          </svg>
          Tôi có xe, tìm khách
        </button>
      </div>

      <%# Search fields %>
      <div class="p-4 sm:p-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">

          <%# Origin input %>
          <div>
            <label for="origin" class="block text-xs text-[#4B5563] mb-1.5 text-left" style="font-weight: 600;">Điểm xuất phát</label>
            <div class="relative">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none z-10">
                <svg class="w-4 h-4 text-[#16A34A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <input
                type="text"
                id="origin"
                placeholder="Hà Nội, TP.HCM, Đà Nẵng..."
                class="w-full bg-[#F9FAFB] border border-gray-200 rounded-xl pl-10 pr-4 py-3 text-sm text-[#1F2937] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#16A34A] focus:border-transparent transition-all duration-200"
                style="font-weight: 500;"
              >
            </div>
          </div>

          <%# Destination input %>
          <div>
            <label for="destination" class="block text-xs text-[#4B5563] mb-1.5 text-left" style="font-weight: 600;">Điểm đến</label>
            <div class="relative">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none z-10">
                <svg class="w-4 h-4 text-[#22C55E]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/>
                </svg>
              </div>
              <input
                type="text"
                id="destination"
                placeholder="Hoà Lạc, Bình Dương, Hải Phòng..."
                class="w-full bg-[#F9FAFB] border border-gray-200 rounded-xl pl-10 pr-4 py-3 text-sm text-[#1F2937] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#16A34A] focus:border-transparent transition-all duration-200"
                style="font-weight: 500;"
              >
            </div>
          </div>

          <%# Vehicle type %>
          <div id="vehicle-filter">
            <label class="block text-xs text-[#4B5563] mb-1.5 text-left" style="font-weight: 600;">Loại xe</label>
            <div class="flex gap-2">
              <button onclick="selectVehicle(this)" class="vehicle-btn flex-1 flex flex-col items-center gap-1 py-2.5 px-2 rounded-xl border-2 border-[#16A34A] bg-[#F0FFF4] text-[#16A34A] text-xs cursor-pointer transition-all duration-200" style="font-weight: 600;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Tất cả
              </button>
              <button onclick="selectVehicle(this)" class="vehicle-btn flex-1 flex flex-col items-center gap-1 py-2.5 px-2 rounded-xl border-2 border-gray-200 bg-white text-[#6B7280] text-xs hover:border-[#16A34A] hover:bg-[#F0FFF4] hover:text-[#16A34A] cursor-pointer transition-all duration-200" style="font-weight: 500;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                </svg>
                Xe máy
              </button>
              <button onclick="selectVehicle(this)" class="vehicle-btn flex-1 flex flex-col items-center gap-1 py-2.5 px-2 rounded-xl border-2 border-gray-200 bg-white text-[#6B7280] text-xs hover:border-[#16A34A] hover:bg-[#F0FFF4] hover:text-[#16A34A] cursor-pointer transition-all duration-200" style="font-weight: 500;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17a2 2 0 100-4 2 2 0 000 4zM16 17a2 2 0 100-4 2 2 0 000 4zM3 11l1.5-5h15L21 11M3 11h18M3 11l-1 3h20l-1-3"/>
                </svg>
                Ô tô
              </button>
            </div>
          </div>

          <%# Date-time picker (replaces date-only picker) %>
          <div>
            <label for="depart-datetime" class="block text-xs text-[#4B5563] mb-1.5 text-left" style="font-weight: 600;">Ngày & giờ đi</label>
            <div class="relative">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none z-10">
                <svg class="w-4 h-4 text-[#6B7280]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
              <input
                type="datetime-local"
                id="depart-datetime"
                value="<%= Time.now.strftime('%Y-%m-%dT%H:%M') %>"
                min="<%= Time.now.strftime('%Y-%m-%dT%H:%M') %>"
                class="w-full bg-[#F9FAFB] border border-gray-200 rounded-xl pl-10 pr-4 py-3 text-sm text-[#1F2937] focus:outline-none focus:ring-2 focus:ring-[#16A34A] focus:border-transparent cursor-pointer transition-all duration-200"
                style="font-weight: 500;"
              >
            </div>
          </div>

        </div>

        <%# CTA button %>
        <a
          href="/posts"
          id="search-btn"
          class="block w-full text-center bg-[#16A34A] hover:bg-[#15803D] active:bg-[#14532D] text-white text-base py-3.5 rounded-xl transition-colors duration-200 cursor-pointer"
          style="font-weight: 700;"
        >
          <span id="search-btn-text">Tìm chuyến xe</span>
          <svg class="w-5 h-5 inline ml-1.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </a>

        <p class="mt-3 text-xs text-[#6B7280] text-center">
          Muốn đăng chuyến của bạn?
          <a href="/posts/new" class="text-[#16A34A] hover:underline cursor-pointer" style="font-weight: 600;">Đăng ngay miễn phí</a>
        </p>
      </div>
    </div>

    <%# Trust badges %>
    <div class="flex flex-wrap items-center justify-center gap-4 mt-6">
      <% [
        "Miễn phí 100%",
        "Không phí ẩn",
        "Xem SĐT & Zalo ngay"
      ].each do |badge| %>
        <div class="flex items-center gap-1.5 text-sm text-[#4B5563]">
          <svg class="w-4 h-4 text-[#16A34A]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <%= badge %>
        </div>
      <% end %>
    </div>

  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden sm:flex flex-col items-center gap-1 text-[#6B7280] animate-bounce">
    <span class="text-xs">Tìm hiểu thêm</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<%# ===== TREE SILHOUETTE DIVIDER ===== %>
<div class="bg-[#064E3B] relative overflow-hidden" aria-hidden="true" style="height: 80px;">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="absolute bottom-0 left-0 w-full h-full" fill="#F0FFF4">
    <%# Forest treeline silhouette %>
    <path d="M0,80 L0,55 Q30,20 60,40 Q80,10 100,35 Q120,5 145,30 Q165,0 190,28 Q210,8 235,32 Q255,15 280,38 Q300,5 325,30 Q345,12 370,35 Q395,0 420,28 Q440,10 465,32 Q485,5 510,30 Q535,18 560,40 Q580,8 605,30 Q625,0 650,25 Q675,10 700,35 Q720,5 745,28 Q765,12 790,35 Q815,2 840,28 Q860,10 885,32 Q905,5 930,30 Q955,15 980,38 Q1000,5 1025,28 Q1045,10 1070,32 Q1095,0 1120,25 Q1140,8 1165,30 Q1185,5 1210,28 Q1235,12 1260,35 Q1280,0 1305,25 Q1325,10 1350,32 Q1370,5 1395,28 L1440,30 L1440,80 Z"/>
  </svg>
</div>

<%# ===== ECO IMPACT STATS ===== %>
<section class="py-12 sm:py-16 px-4 sm:px-6 bg-[#064E3B]">
  <div class="max-w-6xl mx-auto">
    <p class="text-center text-[#86EFAC] text-sm mb-10" style="font-weight: 500;">Mỗi chuyến đi chung là một hành động nhỏ — tác động lớn</p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
      <% [
        {
          num: "50–70%",
          label: "tiết kiệm chi phí\ndi chuyển",
          icon: '<path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>'
        },
        {
          num: "~2.1kg",
          label: "CO₂ giảm mỗi\n40km/chuyến",
          icon: '<path d="M17 8C8 10 5.9 16.17 3.82 19.49c.33.08.69.12 1.07.12 2.76 0 6.89-1.73 9.36-6.74.61-1.23 1.64-2.96 2.75-3.87zM22 2S14 2 9 7c-2.65 2.65-3 7.87-3 7.87S9 13 11.87 9.13C13.64 7.36 22 2 22 2z"/>'
        },
        {
          num: "1 xe",
          label: "thay 2–4 xe\ntrên đường",
          icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17a2 2 0 100-4 2 2 0 000 4zM16 17a2 2 0 100-4 2 2 0 000 4zM3 11l1.5-5h15L21 11M3 11h18M3 11l-1 3h20l-1-3"/>'
        },
        {
          num: "Toàn quốc",
          label: "mọi tuyến đường\nViệt Nam",
          icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>'
        }
      ].each do |stat| %>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-[#065F46] rounded-xl flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-[#4ADE80]" fill="<%= stat[:num] == '50–70%' || stat[:num] == '~2.1kg' ? 'currentColor' : 'none' %>" stroke="<%= stat[:num] == '50–70%' || stat[:num] == '~2.1kg' ? 'none' : 'currentColor' %>" viewBox="0 0 24 24" aria-hidden="true">
              <%= stat[:icon].html_safe %>
            </svg>
          </div>
          <div class="text-2xl sm:text-3xl text-white mb-1" style="font-weight: 800;"><%= stat[:num] %></div>
          <div class="text-xs text-[#A7F3D0] leading-relaxed whitespace-pre-line"><%= stat[:label] %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== HOW IT WORKS ===== %>
<section class="py-16 sm:py-20 px-4 sm:px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 mb-3">
        <svg class="w-5 h-5 text-[#16A34A]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17 8C8 10 5.9 16.17 3.82 19.49c.33.08.69.12 1.07.12 2.76 0 6.89-1.73 9.36-6.74.61-1.23 1.64-2.96 2.75-3.87zM22 2S14 2 9 7c-2.65 2.65-3 7.87-3 7.87S9 13 11.87 9.13C13.64 7.36 22 2 22 2z"/>
        </svg>
        <h2 class="text-2xl sm:text-3xl text-[#14532D]" style="font-weight: 800;">Cách hoạt động</h2>
        <svg class="w-5 h-5 text-[#16A34A]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17 8C8 10 5.9 16.17 3.82 19.49c.33.08.69.12 1.07.12 2.76 0 6.89-1.73 9.36-6.74.61-1.23 1.64-2.96 2.75-3.87zM22 2S14 2 9 7c-2.65 2.65-3 7.87-3 7.87S9 13 11.87 9.13C13.64 7.36 22 2 22 2z"/>
        </svg>
      </div>
      <p class="text-[#4B5563] text-base max-w-md mx-auto">Chỉ 3 bước đơn giản</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <% [

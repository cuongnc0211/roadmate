<%# ===== SCRIPTS ===== %>
<script>
  function switchTab(tab) {
    const findRideTab = document.getElementById('tab-find-ride');
    const findPassengerTab = document.getElementById('tab-find-passenger');
    const vehicleFilter = document.getElementById('vehicle-filter');
    const searchBtnText = document.getElementById('search-btn-text');

    const activeStyle = { borderColor: '#16A34A', backgroundColor: '#F0FFF4', color: '#16A34A', fontWeight: '600' };
    const inactiveStyle = { borderColor: 'transparent', backgroundColor: '', color: '#6B7280', fontWeight: '500' };

    if (tab === 'find-ride') {
      applyTabStyle(findRideTab, activeStyle);
      applyTabStyle(findPassengerTab, inactiveStyle);
      vehicleFilter.style.display = '';
      searchBtnText.textContent = 'Tìm chuyến xe';
    } else {
      applyTabStyle(findPassengerTab, activeStyle);
      applyTabStyle(findRideTab, inactiveStyle);
      vehicleFilter.style.display = 'none';
      searchBtnText.textContent = 'Tìm khách đi cùng';
    }
  }

  function applyTabStyle(el, style) {
    el.style.borderBottomColor = style.borderColor;
    el.style.backgroundColor = style.backgroundColor;
    el.style.color = style.color;
    el.style.fontWeight = style.fontWeight;
  }

  function selectVehicle(btn) {
    document.querySelectorAll('.vehicle-btn').forEach(function(b) {
      b.style.borderColor = '#E5E7EB';
      b.style.backgroundColor = '#FFFFFF';
      b.style.color = '#6B7280';
      b.style.fontWeight = '500';
    });
    btn.style.borderColor = '#16A34A';
    btn.style.backgroundColor = '#F0FFF4';
    btn.style.color = '#16A34A';
    btn.style.fontWeight = '600';
  }
</script>
